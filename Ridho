        /* === PENGATURAN DASAR === */
        body {
            background-color: #222;
            color: white;
            font-family: sans-serif;
            text-align: center;
            padding: 20px;
            margin: 0;
            transition: background-color 0.3s, color 0.3s;
        }

        /* === TOMBOL MODE === */
        .tombol-mode {
            position: fixed;
            top: 10px;
            right: 10px;
            background: #e91e63;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 14px;
            cursor: pointer;
            z-index: 100;
            font-weight: bold;
        }

        /* === LAYAR DEPAN === */
        #halaman-depan { display: block; }
        
        .kartu-tombol {
            background: white;
            width: 260px;
            margin: 20px auto;
            padding: 10px;
            border-radius: 15px;
            color: black;
            cursor: pointer;
            border: 2px solid #e91e63;
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
        }
        .kartu-tombol:hover { transform: scale(1.05); }
        
        .kartu-tombol img {
            width: 100%;
            height: 260px;
            object-fit: cover;
            object-position: center top;
            border-radius: 10px;
            background-color: #eee;
        }
        .kartu-tombol h2 { margin: 10px 0 5px 0; font-size: 20px; }
        .kartu-tombol p { margin: 0 0 5px 0; font-size: 14px; color: #666; }

        /* === LAYAR GALERI === */
        .halaman-galeri {
            display: none;
            background-color: #ffe4ec;
            color: #333;
            min-height: 100vh;
            padding-top: 20px;
            transition: background-color 0.3s, color 0.3s;
        }
        
        .gallery-box {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            padding: 20px;
            max-width: 600px;
            margin: 0 auto;
        }

        .foto-item {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            cursor: zoom-in;
        }
        .foto-item img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            display: block;
        }
        .nomor {
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 5px;
            font-size: 12px;
        }

        .tombol-kembali {
            background: #e91e63;
            color: white;
            padding: 10px 20px;
            border-radius: 20px;
            cursor: pointer;
            font-weight: bold;
            display: inline-block;
            margin-bottom: 10px;
        }

        /* === MODAL FOTO GEDE === */
        #modal-foto {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0; top: 0;
            width: 100%; height: 100%;
            background-color: rgba(0,0,0,0.97);
            justify-content: center;
            align-items: center;
            padding: 0;
        }
        #modal-foto img {
            width: 100%; 
            height: auto;
            max-height: 100%;
            object-fit: contain;
            display: block;
        }
        #tutup-modal {
            position: absolute;
            top: 15px;
            right: 15px;
            color: white;
            font-size: 35px;
            font-weight: bold;
            cursor: pointer;
            z-index: 1001;
            background: rgba(0,0,0,0.5);
            border-radius: 50%;
            width: 30px;
            height: 30px;
            line-height: 30px;
        }

        /* === MODE PUTIH === */
        body.light-mode {
            background-color: #f5f5f5;
            color: #222;
        }
        body.light-mode .halaman-galeri {
            background-color: #ffffff;
            color: #222;
        }

    </style>
