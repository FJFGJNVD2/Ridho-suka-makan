    <script>
        // FUNGSI BUKA GALERI
        function bukaGaleri(nama) {
            document.getElementById('halaman-depan').style.display = 'none';
            document.getElementById('halaman-' + nama).style.display = 'block';
        }

        // FUNGSI TUTUP GALERI
        function tutupGaleri() {
            document.getElementById('halaman-alya').style.display = 'none';
            document.getElementById('halaman-anna').style.display = 'none';
            document.getElementById('halaman-reze').style.display = 'none';
            document.getElementById('halaman-depan').style.display = 'block';
        }

        // Ganti Mode
        function gantiMode() {
            var body = document.body;
            var btn = document.querySelector('.tombol-mode');
            body.classList.toggle("light-mode");
            if (body.classList.contains("light-mode")) {
                btn.innerHTML = "🌙 Mode Gelap";
            } else {
                btn.innerHTML = "☀️ Mode Terang";
            }
        }

        // FUNGSI ZOOM
        function bukaFoto(src) {
            var modal = document.getElementById('modal-foto');
            var imgBesar = document.getElementById('gambar-besar');
            modal.style.display = 'flex'; 
            imgBesar.src = src; 
        }

        function tutupFoto() {
            document.getElementById('modal-foto').style.display = 'none';
        }
